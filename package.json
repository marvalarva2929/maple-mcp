{
  "name": "maple-mcp",
  "version": "0.1.0",
  "description": "MCP server for exclusive developer tool discounts",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "maple": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && cp -r src/data dist/ && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "deploy": "gh-pages -d website"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "gh-pages": "^6.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
